{
    "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
    "logo": null,
    "display": {
        "separator": " ›  "
    },
    "modules": [
	"break",
        {
            "type": "os",
            "key": "OS  ",
            "keyColor": "red"   
        },
        {
            "type": "kernel",
            "key": "KER ",
            "keyColor": "green"
        },
        {
            "type": "packages",
            "format": "{} (brew)",
            "key": "PKG ",
            "keyColor": "yellow"
        },
        {
            "type": "shell",
            "key": "SH  ",
            "keyColor": "blue"
        },
        {
            "type": "terminal",
            "key": "TER ",
            "keyColor": "magenta"
        },
        {
            "type": "wm",
            "key": "WM  ",
            "keyColor": "cyan"
        },
        "break"
    ]
}
