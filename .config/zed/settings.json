{
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },

  "restore_on_startup": "launchpad",
  "ssh_connections": [
    {
      "host": "201.199.127.213",
      "args": [],
      "projects": [
        {
          "paths": ["/home/jgarro"],
        },
        {
          "paths": ["/home/jgarro/actualapi"],
        },
        {
          "paths": ["/home/jgarro/n8n"],
        },
      ],
    },
  ],
  "agent": {
    "default_profile": "write",
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-haiku-4.5",
      "enable_thinking": true,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "indent_guides": {
    "coloring": "indent_aware",
    "background_coloring": "disabled",
  },
  "colorize_brackets": true,
  "edit_predictions": {
    "provider": "copilot",
  },
  "disable_ai": false,

  "project_panel": {
    "dock": "right",
  },

  "icon_theme": {
    "mode": "system",
    "light": "Light Charmed Icons",
    "dark": "Catppuccin Mocha",
  },

  "ui_font_size": 16,

  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 16,

  "theme": {
    "mode": "system",
    "light": "Aizen Light",
    "dark": "Catppuccin Espresso (Blur) [Light]",
  },

  "active_pane_modifiers": {
    "border_size": 1.0,
    "inactive_opacity": 0.82,
  },

  "notification_panel": {
    "dock": "right",
  },

  "outline_panel": {
    "dock": "right",
  },

  "terminal": {
    "font_family": "Hack Nerd Font Mono",
    "minimum_contrast": 0,

    "shell": {
      "program": "/opt/homebrew/bin/fish",
    },

    "detect_venv": {
      "on": {
        "directories": [".venv", "venv"],
        "activate_script": "fish",
      },
    },
  },

  "languages": {
    "LOG": {
      "soft_wrap": "bounded",
      "preferred_line_length": 250,
    },
  },
}
